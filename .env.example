# =====================================================================
# 临考 (Linkao) — Environment Template
# Copy to .env.local for development; mirror to Vercel env for production
# NEVER commit real secrets. .env.local is in .gitignore by Next.js default.
# =====================================================================

# ----- Supabase (https://supabase.com/dashboard/project/_/settings/api) -----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to client. Used in API routes and server actions.
SUPABASE_SERVICE_ROLE_KEY=

# ----- Anthropic (https://console.anthropic.com/) -----
# Server-only. NEVER put real key in this tracked file — put it in .env.local.
# Endpoint policy (revised 2026-05-11): founder approves routing via openclaudecode.cn 中转.
# Whitelist enforced in lib/anthropic.ts → assertOfficialEndpoint().
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://www.openclaudecode.cn/
ANTHROPIC_MODEL_PRIMARY=claude-opus-4-7
ANTHROPIC_MODEL_BULK=claude-haiku-4-5-20251001

# ----- OpenAI (optional for MVP — Haiku 4.5 replaces gpt-4o-mini in v0.1) -----
# Uncomment when you actually need OpenAI. Keep red-line: api.openai.com only.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ----- App (Vercel sets NEXT_PUBLIC_VERCEL_URL automatically in prod) -----
# Dev: http://localhost:3000
# Production target: https://linkaoai.com (registered 2026-05-10, DNS to be bound on Vercel Day 7)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Optional analytics / observability (Day 6+) -----
# POSTHOG_KEY=
# SENTRY_DSN=

# ----- EPay (彩虹易支付) — 全 5 个变量都填才会启用自动支付 -----
# 留空时 /api/payment/epay/* 自动 503，用户走手动渠道（微信/支付宝转账）。
# 生产环境 2026-05-19 已配置（mxpay.byesmart.store），从 admin 后台拿凭证。
# 本地开发不需要真值；想测 EPay 流程时在 .env.local 填一组 sandbox 凭证。
# EPAY_PID=10002
# EPAY_KEY=                                              # 商户密钥（绝对不进 git）
# EPAY_URL=https://mxpay.byesmart.store/xpay/epay/submit.php
# EPAY_NOTIFY_URL=https://linkaoai.com/api/payment/epay/notify
# EPAY_RETURN_URL=https://linkaoai.com/api/payment/epay/return

