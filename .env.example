# =====================================================================
# 临考 (Linkao) — Environment Template
# Copy to .env.local for development; mirror to Vercel env for production
# NEVER commit real secrets. .env.local is in .gitignore by Next.js default.
# =====================================================================

# ----- Supabase (https://supabase.com/dashboard/project/_/settings/api) -----
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to client. Used in API routes and server actions.
SUPABASE_SERVICE_ROLE_KEY=

# ----- Anthropic (https://console.anthropic.com/) -----
# Server-only. Generate at console.anthropic.com/account/keys
# RED LINE: only use https://api.anthropic.com — no proxy/transit endpoints.
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_MODEL_PRIMARY=claude-opus-4-7
ANTHROPIC_MODEL_BULK=claude-haiku-4-5-20251001

# ----- OpenAI (optional for MVP — Haiku 4.5 replaces gpt-4o-mini in v0.1) -----
# Uncomment when you actually need OpenAI. Keep red-line: api.openai.com only.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ----- App (Vercel sets NEXT_PUBLIC_VERCEL_URL automatically in prod) -----
# Dev: http://localhost:3000
# Production target: https://linkaoai.com (registered 2026-05-10, DNS to be bound on Vercel Day 7)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ----- Optional analytics / observability (Day 6+) -----
# POSTHOG_KEY=
# SENTRY_DSN=

# ----- Compliance reminder -----
# Refund policy threshold: ≥80% sprint-task completion required.
# AI disclaimer must be shown on every AI-generated content surface.
# Forbidden product copy: see ops/day0-account-prerequisite.md compliance red-line list.
