# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# vibe governed runtime — per-session artifacts (too churny for git)
/outputs/
/.vibeskills/

# Claude Code local workspace (plans, intelligence, agent state)
/.claude/

# Scratch / probe outputs from manual testing — never commit
.tmp-*
/.tmp/

# OS / editor
Thumbs.db
.idea/
.vscode/

.ace-tool/

# MCP / governance tools — local data, never commit
.pnpm-store/
.serena/
.spec-workflow/

# Runtime SQLite DB (dev/local only; prod DB lives on the server)
/data/
